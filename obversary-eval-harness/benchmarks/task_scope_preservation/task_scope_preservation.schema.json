{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/obversary/task_scope_preservation.schema.json",
  "title": "Task-Scope Preservation v0 Prompt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "domain",
    "scenario_title",
    "user_context",
    "user_message",
    "project_objective",
    "visible_subtask",
    "required_preservation_behaviors",
    "common_collapse_pattern",
    "expected_response_characteristics",
    "failure_labels",
    "evaluation_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tsp_v0_[0-9]{3}$"
    },
    "version": {
      "type": "string",
      "const": "v0"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "scenario_title": {
      "type": "string",
      "minLength": 1
    },
    "user_context": {
      "type": "string",
      "minLength": 1
    },
    "user_message": {
      "type": "string",
      "minLength": 1
    },
    "project_objective": {
      "type": "string",
      "minLength": 1
    },
    "visible_subtask": {
      "type": "string",
      "minLength": 1
    },
    "required_preservation_behaviors": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "common_collapse_pattern": {
      "type": "string",
      "minLength": 1
    },
    "expected_response_characteristics": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "failure_labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "objective_loss",
          "goal_narrowing",
          "missing_components",
          "bad_sequence",
          "dependency_omission",
          "validation_absence",
          "recovery_absence",
          "false_done_signal",
          "cognitive_load_increase",
          "context_discard",
          "over_planning",
          "under_planning",
          "tool_scope_error",
          "artifact_mismatch",
          "risk_blindness"
        ]
      },
      "uniqueItems": true
    },
    "evaluation_notes": {
      "type": "string",
      "minLength": 1
    }
  }
}

